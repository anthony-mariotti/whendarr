{
  "name": "whendarr",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check": "turbo run check",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "dev:docker:build": "docker compose -f docker/compose.develop.yml --profile build up -d",
    "dev:docker:direct": "docker compose -f docker/compose.develop.yml --profile direct up -d",
    "dev:docker:traefik": "docker compose -f docker/compose.develop.yml --profile traefik up -d",
    "dev:docker:traefik:subpath": "docker compose -f docker/compose.develop.yml --profile traefik-subpath up -d",
    "dev:docker:down": "docker compose -f docker/compose.develop.yml --profile down down -t 0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "catalog:eslint",
    "eslint": "catalog:eslint",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "catalog:tailwind",
    "turbo": "^2.9.6",
    "typescript": "catalog:",
    "typescript-eslint": "^8.58.1"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "engines": {
    "node": ">=18",
    "pnpm": ">=10.0.0"
  }
}
